# NSCA Demo — Environment Variables Template
# Copy this file to .env for local development (never commit .env)
#
# Production: set these as secrets in Streamlit Community Cloud:
#   App Settings → Secrets → paste TOML-formatted values

# ── Optional: LLM integration (Layer 4) ───────────────────────────────────────
# Required only when "Enable external LLM" is checked in the sidebar
OPENAI_API_KEY=sk-...

# ── Optional: Experiment tracking ─────────────────────────────────────────────
# Required only if wandb logging is enabled during training
WANDB_API_KEY=

# ── Optional: Google Drive checkpoint download ─────────────────────────────────
# Folder ID from the shared Drive link (scripts/download_checkpoints.py)
GOOGLE_DRIVE_FOLDER_ID=
