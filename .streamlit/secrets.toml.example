# Streamlit Community Cloud secrets template
# In the Cloud dashboard: App → Settings → Secrets, paste this (without the comments).
# Never commit an actual secrets.toml — .gitignore already excludes .streamlit/secrets.toml.

# Optional: enables Layer 4 LLM integration
OPENAI_API_KEY = "sk-..."

# Optional: experiment tracking
WANDB_API_KEY = ""

# Optional: Google Drive folder for checkpoint downloads
GOOGLE_DRIVE_FOLDER_ID = ""
